@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-10">
        <div class="card border-0 shadow-lg overflow-hidden text-white" 
             style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); border-radius: 30px;">
            <div class="card-body p-5 text-center my-4">
                <i class="bi bi-rocket-takeoff display-1 mb-4"></i>
                <h1 class="fw-bold display-4 mb-3">YKS Koçluk Sistemi</h1>
                <p class="fs-5 opacity-75 mb-5 mx-auto" style="max-width: 700px;">
                    Hayallerindeki üniversiteye giden yolda asla yalnız değilsin. 
                    Profesyonel koçlar eşliğinde planlı çalış, hedeflerine ulaş.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary shadow">
                        Giriş Yap
                    </a>
                    <a asp-controller="Account" asp-action="Kayit" class="btn btn-outline-light btn-lg rounded-pill px-5 fw-bold border-2">
                        Kayıt Ol
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5 g-4 justify-content-center">
    <div class="col-md-4">
        <div class="card h-100 p-4 border-0 shadow-sm text-center">
            <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-person-check h2 mb-0"></i>
            </div>
            <h5 class="fw-bold">Birebir Takip</h5>
            <p class="text-secondary small">Sana özel atanan koçunla haftalık derslerini ve gelişimini analiz et.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 border-0 shadow-sm text-center">
            <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-list-check h2 mb-0"></i>
            </div>
            <h5 class="fw-bold">Ödev Sistemi</h5>
            <p class="text-secondary small">Koçunun verdiği görevleri yap, sistemden işaretle, tamamlama oranını takip et.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 border-0 shadow-sm text-center">
            <div class="rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-graph-up-arrow h2 mb-0"></i>
            </div>
            <h5 class="fw-bold">Hedef Odallı</h5>
            <p class="text-secondary small">Sayısal, Sözel veya Eşit Ağırlık stratejileriyle netlerini artırmaya odaklan.</p>
        </div>
    </div>
</div>

<div class="row mt-5 justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 bg-white p-4 shadow-sm" style="border-left: 5px solid #2563eb !important;">
            <div class="d-flex align-items-center">
                <i class="bi bi-info-circle-fill text-primary h3 me-3 mb-0"></i>
                <p class="mb-0 fw-medium text-dark">
                    Biliyor musun? Düzenli koçluk alan öğrencilerin başarı oranı, almayanlara göre %40 daha yüksektir.
                </p>
            </div>
        </div>
    </div>
</div>