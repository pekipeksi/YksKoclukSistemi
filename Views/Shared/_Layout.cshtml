<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Focus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --brand-color: #2563eb;
            --bg-body: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
        }

        .navbar {
            background: white !important;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 15px 0;
        }

        .navbar-brand {
            font-weight: 800;
            color: #000 !important;
            letter-spacing: -1px;
        }

        /* Profil Özeti Stili */
        .profile-section {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #f1f5f9;
            padding: 6px 15px;
            border-radius: 12px;
        }

        .avatar-circle {
            width: 32px;
            height: 32px;
            background: var(--brand-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .user-name {
            font-weight: 600;
            font-size: 0.9rem;
            color: #1e293b;
        }

        /* Çıkış Yap Butonu - Sade ve Net */
        .btn-logout {
            color: #e11d48;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 8px 16px;
            border-radius: 10px;
            transition: 0.2s;
        }

        .btn-logout:hover {
            background: #fff1f2;
            color: #be123c;
        }
    </style>
</head>
<body>
    <nav class="navbar shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">FOCUS</a>

            <div class="d-flex align-items-center gap-3">
                @if (Context.Session.GetString("Ad") != null)
                {
                    // --- BURADA İSİM MANTIĞINI DÜZENLEDİK ---
                    // Eğer rol 'Yonetici' ise ekranda 'Yönetici' yazsın, değilse ismini (Örn: Ali) yazsın.
                    string rol = Context.Session.GetString("Rol")?.Trim();
                    string isim = Context.Session.GetString("Ad");

                    string gorunecekIsim = (rol == "Yonetici") ? "Yönetici" : isim;
                    string basHarf = !string.IsNullOrEmpty(gorunecekIsim) ? gorunecekIsim.Substring(0, 1).ToUpper() : "?";

                        <div class="profile-section">
                            <div class="avatar-circle">
                            @basHarf
                            </div>
                            <span class="user-name">@gorunecekIsim</span>
                        </div>

                        <a class="btn-logout" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Çıkış Yap
                        </a>
                }
            </div>
        </div>
    </nav>

    <main role="main" class="container py-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>