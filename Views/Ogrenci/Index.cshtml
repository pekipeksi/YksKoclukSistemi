@model List<YksKoclukSistemi.Models.HaftalikProgram>

@{
    ViewData["Title"] = "Programlarım";
}

<div class="container mt-4">
    <div class="bg-white p-4 rounded-4 shadow-sm mb-5 border d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">Hoş Geldin, @Context.Session.GetString("Ad")! 👋</h2>
            <p class="text-secondary mb-0">Programlarını buradan takip edebilirsin.</p>
        </div>
        <div class="text-end">
            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 1px;">Eğitim Koçum</small>
            <div class="d-flex align-items-center gap-2 mt-1">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                    <i class="bi bi-person-fill"></i>
                </div>
                <h5 class="fw-bold text-dark mb-0">@ViewBag.KocAdSoyad</h5>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3"><i class="bi bi-collection me-2 text-primary"></i>Haftalık Programlarım</h5>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var prog in Model)
            {
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 border-0 shadow-sm" style="border-radius: 15px; transition: transform 0.2s;">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between mb-3">
                                        <span class="badge bg-primary rounded-pill px-3">Haftalık Plan</span>
                                        <small class="text-secondary">@(prog.Gorevler != null ? prog.Gorevler.Count : 0) Görev</small>
                                    </div>

                                    <h5 class="fw-bold text-dark mb-1">@prog.BaslangicTarihi.ToString("dd MMMM")</h5>
                                    <p class="text-secondary small mb-4">@prog.BitisTarihi.ToString("dd MMMM yyyy")</p>

                                    <a asp-action="ProgramDetay" asp-route-id="@prog.Id" class="btn btn-light w-100 text-primary fw-bold rounded-3 stretched-link">
                                        Programı Görüntüle <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
            }
        }
        else
        {
                <div class="col-12">
                    <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-dashed">
                        <i class="bi bi-calendar-x display-4 text-secondary opacity-25 mb-3 d-block"></i>
                        <h5 class="fw-bold text-dark">Henüz Programın Yok</h5>
                        <p class="text-muted">Koçun senin için henüz bir program oluşturmamış.</p>
                    </div>
                </div>
        }
    </div>
</div>