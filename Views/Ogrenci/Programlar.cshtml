@model List<YksKoclukSistemi.Models.HaftalikProgram>
@{
    ViewData["Title"] = "Haftalık Planlar";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="mb-5 mt-4 text-center">
            <h2 class="fw-bold">Haftalık Planlar</h2>
            <p class="text-secondary">Tüm programlara buradan hızlıca ulaşabilirsin.</p>
        </div>

        <div class="row g-4">
            @* Yeni Hafta Oluştur Kartı (Sadece Koç Panelinde görünür, Öğrencide bu kısmı silebilirsin) *@
            @if (Context.Session.GetString("Rol") == "Koc")
            {
                    <div class="col-md-4">
                        <a href="javascript:void(0);" onclick="yeniHaftaOlustur()" class="text-decoration-none">
                            <div class="card h-100 border-0 shadow-sm p-4 text-center d-flex align-items-center justify-content-center" 
                                 style="border: 2px dashed #cbd5e1 !important; background: transparent; transition: 0.3s;">
                                <i class="bi bi-plus-lg display-4 text-primary mb-2"></i>
                                <h5 class="fw-bold text-dark">Yeni Hafta Oluştur</h5>
                                <p class="small text-secondary mb-0">Program eklemek için tıkla</p>
                            </div>
                        </a>
                    </div>
            }

            @foreach (var p in Model.OrderByDescending(x => x.HaftaNumarasi))
            {
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm p-3 position-relative overflow-hidden">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h4 class="fw-bold text-primary mb-0">@p.HaftaNumarasi. Hafta</h4>
                                @if (Context.Session.GetString("Rol") == "Koc")
                                {
                                            <form asp-action="HaftaSil" asp-route-id="@p.Id" method="post" onsubmit="return confirm('Silmek istediğine emin misin?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0 opacity-50">
                                                    <i class="bi bi-trash3"></i> Sil
                                                </button>
                                            </form>
                                }
                                </div>

                                <p class="text-secondary small mb-4">
                                    <i class="bi bi-calendar3 me-1"></i> @p.BaslangicTarihi.ToString("dd MMM") - @p.BitisTarihi.ToString("dd MMM")
                                </p>

                                <div class="d-grid">
                                    <a asp-action="ProgramDetay" asp-route-programId="@p.Id" class="btn btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                        İncele <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
            }
        </div>
    </div>
</div>

<style>
    .card:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important; }
</style>